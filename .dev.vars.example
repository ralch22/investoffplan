# Copy to .dev.vars for local preview/deploy (never commit .dev.vars).
# Public vars can also live in wrangler.jsonc "vars".

# Preview (default):
NEXT_PUBLIC_SITE_URL=https://investoffplan-preview.emerge-digital.workers.dev
# Serve catalog from D1 API routes (requires npm run db:seed:local)
NEXT_PUBLIC_CATALOG_API=1
# Production (wrangler.production.jsonc):
# NEXT_PUBLIC_SITE_URL=https://investoffplan.com

# GA4 — InvestOffPlan property only (do NOT reuse VaultOS G-VVQXDS8BK8)
# Create a separate property in GA4 Admin, then set Measurement ID per environment.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional — Cloudflare Turnstile (forms skip widget when site key is unset)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Server-only — set via: npx wrangler secret put TURNSTILE_SECRET_KEY
TURNSTILE_SECRET_KEY=

# Server-only GA4 Measurement Protocol secret (used by /api/leads to emit generate_lead server-side).
# Set via: npx wrangler secret put GA4_MP_SECRET  (on preview + production workers)
# GA4_MP_SECRET=  (do not put real value here)

# Optional enrichment pipeline
FIRECRAWL_API_KEY=